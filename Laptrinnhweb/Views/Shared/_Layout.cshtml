<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Laptrinnhweb</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <!-- NAVBAR -->
    <header>
        <nav id="navbar" class="navbar navbar-expand-lg fixed-top navbar-dark bg-dark shadow-sm">

            <div class="container-fluid px-4">

                <!-- LOGO -->
                <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
                    🍽 Restaurant
                </a>

                <!-- TOGGLE -->
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <i class="bi bi-list fs-2"></i>
                </button>

                <!-- MENU -->
                <div class="collapse navbar-collapse justify-content-between" id="navbarContent">

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <!-- Trang chủ -->
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Trang chủ
                            </a>
                        </li>

                        <!-- ĐÃ LOGIN -->
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="BanAns" asp-action="Index">
                                    <i class="bi bi-grid"></i> Sơ đồ bàn
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="MonAns" asp-action="Index">
                                    <i class="bi bi-menu-button"></i> Menu
                                </a>
                            </li>
                        }

                        <!-- ADMIN -->
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-semibold"
                                   asp-area="Admin"
                                   asp-controller="DatBans"
                                   asp-action="Index">
                                    <i class="bi bi-journal-text"></i> Quản lý đặt chỗ
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-warning fw-semibold"
                                   asp-area="Admin"
                                   asp-controller="MonAns"
                                   asp-action="Index">
                                    <i class="bi bi-gear"></i> Quản lý món ăn
                                </a>
                            </li>
                        }

                    </ul>

                    <!-- USER INFO -->
                    <div class="d-flex align-items-center gap-3">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <span class="text-white">
                                👋 @User.Identity.Name
                                <span class="badge bg-warning text-dark ms-1">
                                    @(User.IsInRole("Admin") ? "Admin" : "User")
                                </span>
                            </span>
                        }

                        <partial name="_LoginPartial" />
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <!-- CONTENT -->
    <div style="margin-top:80px;">
        <main role="main" class="container">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center py-3 mt-5">
        <p class="mb-0">© 2026 Laptrinnhweb - Restaurant Booking</p>
    </footer>

    <!-- JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SCROLL EFFECT -->
    <script>
        window.addEventListener("scroll", function () {
            const navbar = document.getElementById("navbar");
            if (window.scrollY > 50) {
                navbar.classList.add("shadow-lg");
            } else {
                navbar.classList.remove("shadow-lg");
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>