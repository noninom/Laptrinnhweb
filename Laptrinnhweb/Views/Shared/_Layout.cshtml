<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Laptrinnhweb</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav id="navbar" class="navbar navbar-expand-lg fixed-top navbar-dark bg-dark shadow-sm">
            <div class="container-fluid px-4">

                <a class="navbar-brand fw-bold fs-4 text-uppercase" asp-controller="Home" asp-action="Index" style="letter-spacing: 1px;">
                    🍽 Restaurant
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <i class="bi bi-list fs-2"></i>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Trang chủ
                            </a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="BanAns" asp-action="Index">
                                    <i class="bi bi-grid"></i> Sơ đồ bàn
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="MonAns" asp-action="Index">
                                    <i class="bi bi-menu-button"></i> Menu
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item ms-lg-2 border-start border-secondary ps-lg-3">
                                <a class="nav-link text-warning fw-semibold" asp-area="Admin" asp-controller="DatBans" asp-action="Index">
                                    <i class="bi bi-journal-text"></i> Quản lý đặt chỗ
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-warning fw-semibold" asp-area="Admin" asp-controller="MonAns" asp-action="Index">
                                    <i class="bi bi-gear"></i> Quản lý món ăn
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-3">
                                <div class="text-white d-flex align-items-center">
                                    <i class="bi bi-person-circle text-warning me-2 fs-5"></i>
                                    <span class="small">
                                        Xin chào, <strong>@User.Identity.Name</strong>
                                        <span class="badge @(User.IsInRole("Admin") ? "bg-danger" : "bg-warning text-dark") ms-1" style="font-size: 0.65rem;">
                                            @(User.IsInRole("Admin") ? "ADMIN" : "USER")
                                        </span>
                                    </span>
                                </div>
                            </li>

                            <li class="nav-item">
                                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                    <button type="submit" class="btn btn-outline-light btn-sm rounded-pill px-3 shadow-sm">
                                        Logout <i class="bi bi-box-arrow-right ms-1"></i>
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold small" asp-area="Identity" asp-page="/Account/Register">REGISTER</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white border border-light rounded-pill px-3 ms-lg-2 fw-semibold small shadow-sm" asp-area="Identity" asp-page="/Account/Login">
                                    LOGIN
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div style="margin-top:0;">
        <main role="main" class="container-fluid p-0">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white text-center py-4 mt-5 border-top border-secondary">
        <p class="mb-0 small">© 2026 Laptrinnhweb - Restaurant Booking System</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        window.addEventListener("scroll", function () {
            const navbar = document.getElementById("navbar");
            if (window.scrollY > 50) {
                navbar.classList.add("shadow-lg");
                navbar.style.backgroundColor = "rgba(33, 37, 41, 0.95)"; /* Làm mờ nhẹ khi cuộn */
            } else {
                navbar.classList.remove("shadow-lg");
                navbar.style.backgroundColor = "#212529";
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>