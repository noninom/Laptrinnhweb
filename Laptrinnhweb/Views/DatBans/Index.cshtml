@model IEnumerable<Laptrinnhweb.Models.DatBan>

@{
    ViewData["Title"] = "Quản lý đặt chỗ";
}

<div class="container mt-5">
    @* Header Section *@
    <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: linear-gradient(to right, #ffffff, #f8f9fa);">
        <div class="card-body d-flex justify-content-between align-items-center p-4">
            <div>
                <h2 class="fw-bold mb-1" style="color: #0d6efd;">
                    <i class="bi bi-journal-check me-2"></i>QUẢN LÝ ĐẶT CHỖ
                </h2>
                <p class="text-muted mb-0">Theo dõi danh sách khách hàng và trạng thái bàn thực tế</p>
            </div>
            <a asp-controller="BanAns" asp-action="Index" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm transition-hover">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i>Sơ đồ bàn
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white shadow-sm rounded-4">
            <img src="https://cdn-icons-png.flaticon.com/512/4076/4076432.png" alt="Empty" style="width: 120px; opacity: 0.5;">
            <h4 class="mt-3 text-muted">Hiện tại không có bàn nào đang hoạt động</h4>
            <a asp-controller="BanAns" asp-action="Index" class="btn btn-outline-primary mt-2 rounded-pill">Đến sơ đồ để đặt bàn</a>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded-4 bg-white overflow-hidden">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th class="ps-4 py-3">KHÁCH HÀNG</th>
                        <th class="py-3">LIÊN HỆ</th>
                        <th class="py-3">THỜI GIAN ĐẶT</th>
                        <th class="py-3 text-center">TRẠNG THÁI</th>
                        <th class="py-3 text-center">VỊ TRÍ BÀN</th>
                        <th class="py-3 text-end pe-4">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle me-3">@item.TenKhachHang.Substring(0, 1).ToUpper()</div>
                                    <span class="fw-bold text-dark">@item.TenKhachHang</span>
                                </div>
                            </td>
                            <td>
                                <div class="text-secondary"><i class="bi bi-telephone me-2"></i>@item.SoDienThoai</div>
                            </td>
                            <td>
                                <div class="text-secondary"><i class="bi bi-calendar-event me-2"></i>@item.NgayDat.ToString("dd/MM/yyyy")</div>
                                <div class="small text-muted"><i class="bi bi-clock me-2"></i>@item.NgayDat.ToString("HH:mm")</div>
                            </td>
                            <td class="text-center">
                                @if (item.TrangThai == 0)
                                {
                                    <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary px-3 py-2 border border-secondary">
                                        <i class="bi bi-hourglass-split me-1"></i>Đang chờ khách
                                    </span>
                                }
                                else if (item.TrangThai == 1)
                                {
                                    <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2 border border-success animate-pulse">
                                        <i class="bi bi-cup-hot-fill me-1"></i>Đang phục vụ
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill bg-opacity-10 bg-info text-info px-3 py-2 border border-info">
                                    <i class="bi bi-geo-alt-fill me-1"></i>Bàn @item.BanAn?.SoBan
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                    @* Nút Xem chi tiết món đã đặt *@
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info text-white px-3 border-0">
                                        <i class="bi bi-search me-1"></i> Xem món
                                    </a>

                                    @if (item.TrangThai == 0)
                                    {
                                        @* Nút Nhận bàn để chuyển trạng thái sang Đang ăn *@
                                        <a asp-action="NhanBan" asp-route-id="@item.Id" class="btn btn-warning text-white px-3 border-0">
                                            <i class="bi bi-check-lg me-1"></i> Nhận bàn
                                        </a>
                                    }
                                    else
                                    {
                                        @* Nút Trả bàn/Thanh toán *@
                                        <form asp-action="Checkout" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-danger px-3 border-0 rounded-0"
                                                    onclick="return confirm('Xác nhận khách đã thanh toán và trả bàn?')">
                                                <i class="bi bi-cash-stack me-1"></i> Trả bàn
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .table thead th {
        font-size: 0.85rem;
        letter-spacing: 1px;
        font-weight: 600;
        border: none;
    }

    .table tbody tr {
        transition: all 0.2s;
        border-bottom: 1px solid #eee;
    }

        .table tbody tr:hover {
            background-color: #f8f9ff;
            transform: scale(1.002);
        }

    .avatar-circle {
        width: 35px;
        height: 35px;
        background-color: #0d6efd;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-weight: bold;
        font-size: 0.9rem;
    }

    .animate-pulse {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.6;
        }

        100% {
            opacity: 1;
        }
    }

    .transition-hover {
        transition: transform 0.2s;
    }

        .transition-hover:hover {
            transform: translateY(-2px);
        }
</style>