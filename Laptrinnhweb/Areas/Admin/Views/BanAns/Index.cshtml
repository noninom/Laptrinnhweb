@model IEnumerable<Laptrinnhweb.Models.BanAn>
<div style="padding-top: 100px; padding-bottom: 50px;">
<div class="container-fluid mt-4 px-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    @* Header Section - Phong cách tối giản sang trọng *@
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-grid-3x3-gap-fill text-primary me-2"></i>SƠ ĐỒ BÀN THỰC TẾ
            </h2>
            <p class="text-muted mb-0 small"><i class="bi bi-info-circle me-1"></i> Quản lý trạng thái và phục vụ khách hàng tại bàn</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="BanAns" asp-action="Create" class="btn btn-dola-add rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-circle-fill me-2"></i>THÊM BÀN MỚI
            </a>
        }
    </div>

    @* Bảng chú thích trạng thái - Thiết kế lại gọn gàng hơn *@
    <div class="d-flex gap-4 mb-4 p-3 bg-white rounded-4 shadow-sm border justify-content-center">
        <div class="status-indicator">
            <span class="dot-lg bg-success-soft"></span> <b>Bàn trống</b>
        </div>
        <div class="status-indicator border-start ps-4">
            <span class="dot-lg bg-danger-soft"></span> <b>Đã có khách</b>
        </div>
        <div class="status-indicator border-start ps-4">
            <span class="dot-lg bg-warning-soft"></span> <b>Đợi nhận bàn</b>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        @foreach (var item in Model)
        {
            var activeBooking = item.DatBans?.OrderByDescending(d => d.Id).FirstOrDefault(d => d.TrangThai != 2);
            var isBusy = item.TrangThai != 0;
            var isPending = isBusy && (activeBooking == null || activeBooking.TrangThai == 0);

            <div class="col-6 col-md-4 col-lg-2-4">
                <div class="table-card-v2 @(isBusy ? (isPending ? "card-pending" : "card-busy") : "card-free")">

                    @if (User.IsInRole("Admin"))
                    {
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Xóa bàn này?')" class="delete-form">
                            <button type="submit" class="btn-delete-table">
                                <i class="bi bi-x"></i>
                            </button>
                        </form>
                    }

                    <div class="card-body-v2 text-center">
                        <div class="table-image-container mb-3">
                            @if (item.SoChoNgoi <= 4)
                            {
                                @* Nếu bàn bận, có thể dùng ảnh có người/màu khác nếu bạn có *@
                                <img src="~/images/@(isBusy ? "ban4cho.jpg" : "ban4cho.jpg")"
                                     class="img-fluid table-img" alt="Bàn 4 chỗ">
                            }
                            else
                            {
                                <img src="~/images/@(isBusy ? "ban6cho.jpg" : "ban6cho.jpg")"
                                     class="img-fluid table-img" alt="Bàn 6 chỗ">
                            }
                        </div>

                        <h4 class="fw-bold mb-1">BÀN @item.SoBan</h4>
                        <div class="seat-badge mb-3">
                            <i class="bi bi-people-fill me-1"></i> @item.SoChoNgoi Chỗ
                        </div>

                        <div class="action-zone">
                            @if (item.TrangThai == 0)
                            {
                                    <a asp-area="" asp-controller="MonAns" asp-action="Index"
                                   asp-route-banId="@item.Id" asp-route-tenBan="@item.SoBan"
                                   class="btn-table-action btn-free-action">
                                    <i class="bi bi-plus-lg me-1"></i> CHỌN BÀN
                                </a>
                            }
                            else if (activeBooking != null && activeBooking.TrangThai == 1)
                            {
                                    <a asp-area="" asp-controller="MonAns" asp-action="Index"
                                   asp-route-banId="@item.Id" asp-route-tenBan="@item.SoBan"
                                   class="btn-table-action btn-busy-action">
                                    <i class="bi bi-cart-plus me-1"></i> GỌI THÊM
                                </a>
                            }
                            else
                            {
                                <div class="pending-status">
                                    <div class="spinner-grow spinner-grow-sm text-danger mb-1" role="status"></div>
                                    <div class="small fw-bold text-uppercase">Đợi nhận bàn</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<</div>
<style>
    /* 1. Layout & Column Setup */
    @@media (min-width: 992px) {
        .col-lg-2-4 {
            flex: 0 0 auto;
            width: 20%;
        }
    }

    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        /* Hình nền đại dương sang trọng */
        background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1559339352-11d035aa65de?auto=format&fit=crop&w=1920&q=80');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat; /* Thêm fixed */
    }
    /* Chỉnh tiêu đề chính */
    h2.text-dark {
        color: #ffffff !important;
    }

    /* --- PHẦN BỔ SUNG CHO HÌNH ẢNH BÀN --- */
    .table-image-container {
        height: 100px; /* Cố định độ cao để hàng lối thẳng tắp */
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .table-img {
        max-height: 100%;
        width: auto;
        object-fit: contain;
        /* Đổ bóng nhẹ cho ảnh để trông thật hơn trên nền trắng */
        filter: drop-shadow(0 8px 12px rgba(0,0,0,0.15));
    }

    /* Hiệu ứng phóng to ảnh khi rê chuột vào Card */
    .table-card-v2:hover .table-image-container {
        transform: scale(1.15) rotate(2deg);
    }

    /* Hiệu ứng riêng cho bàn đang bận */
    .card-busy .table-img {
        filter: drop-shadow(0 8px 12px rgba(220, 53, 69, 0.3));
    }

    /* Đảm bảo Card cũ không bị vỡ bố cục khi thêm ảnh */
    .card-body-v2 {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    /* Chỉnh dòng ghi chú nhỏ */
    p.text-muted {
        color: rgba(255, 255, 255, 0.8) !important; /* Trắng mờ 80% cho dễ nhìn */
    }
    /* 2. Table Card V2 - Glassmorphism & Soft Shadows */
    .table-card-v2 {
        background: white;
        border-radius: 24px;
        padding: 25px 15px;
        position: relative;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(0,0,0,0.05);
        overflow: hidden;
    }

        .table-card-v2:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    /* 3. Color Variations */
    .card-free {
        border-top: 6px solid #28a745;
    }

    .card-busy {
        border-top: 6px solid #dc3545;
        background: #fff5f5;
    }

    .card-pending {
        border-top: 6px solid #ffc107;
        background: #fffdf5;
    }

    .card-free .table-circle-icon {
        background: #e8f5e9;
        color: #28a745;
    }

    .card-busy .table-circle-icon {
        background: #ffebee;
        color: #dc3545;
    }

    .card-pending .table-circle-icon {
        background: #fff8e1;
        color: #ffc107;
    }

    /* 4. Elements Style */
    .table-circle-icon {
        width: 65px;
        height: 65px;
        margin: 0 auto;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
    }

    .seat-badge {
        display: inline-block;
        padding: 4px 12px;
        background: #f1f3f5;
        border-radius: 50px;
        font-size: 0.75rem;
        color: #6c757d;
        font-weight: 600;
    }

    /* 5. Buttons & Actions */
    .btn-table-action {
        width: 100%;
        border: none;
        padding: 10px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.8rem;
        transition: 0.3s;
        text-decoration: none;
        display: block;
    }

    .btn-free-action {
        background: #28a745;
        color: white;
    }

        .btn-free-action:hover {
            background: #218838;
            box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
            color: white;
        }

    .btn-busy-action {
        background: #dc3545;
        color: white;
    }

        .btn-busy-action:hover {
            background: #c82333;
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
            color: white;
        }

    .btn-dola-add {
        background: #002d5b;
        color: #ffc107;
        font-weight: bold;
        border: none;
    }

        .btn-dola-add:hover {
            background: #001d3d;
            color: #ffc107;
        }

    .pending-status {
        color: #dc3545;
        font-size: 0.7rem;
    }

    /* 6. Delete Button */
    .delete-form {
        position: absolute;
        top: 10px;
        right: 10px;
        opacity: 0;
        transition: 0.3s;
    }

    .table-card-v2:hover .delete-form {
        opacity: 1;
    }

    .btn-delete-table {
        background: #f8f9fa;
        border: none;
        color: #adb5bd;
        border-radius: 50%;
        width: 25px;
        height: 25px;
        line-height: 1;
    }

        .btn-delete-table:hover {
            background: #dc3545;
            color: white;
        }

    /* Indicators */
    .dot-lg {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
    }

    .bg-success-soft {
        background-color: #28a745;
        box-shadow: 0 0 0 4px #e8f5e9;
    }

    .bg-danger-soft {
        background-color: #dc3545;
        box-shadow: 0 0 0 4px #ffebee;
    }

    .bg-warning-soft {
        background-color: #ffc107;
        box-shadow: 0 0 0 4px #fff8e1;
    }
</style>