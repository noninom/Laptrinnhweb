@model Laptrinnhweb.Models.DatBan

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="mb-3 no-print">
                <a asp-action="Index" class="text-decoration-none text-secondary">
                    <i class="bi bi-chevron-left"></i> Quay lại danh sách phục vụ
                </a>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden invoice-card">
                @* Header phong cách Dola *@
                <div class="card-header bg-dola-dark py-4 text-center border-0">
                    <h3 class="text-warning fw-bold mb-0">PHIẾU YÊU CẦU PHỤC VỤ</h3>
                    <small class="text-white-50 small text-uppercase" style="letter-spacing: 2px;">Dola Seafood Restaurant</small>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    @* Thông tin đơn hàng *@
                    <div class="row mb-4 border-bottom pb-4">
                        <div class="col-sm-6">
                            <h6 class="text-muted text-uppercase x-small mb-2">Thông tin khách hàng</h6>
                            <h4 class="fw-bold text-dola-dark mb-1">@Model.TenKhachHang</h4>
                            <p class="text-muted mb-0"><i class="bi bi-telephone me-2"></i>@Model.SoDienThoai</p>
                            <p class="text-muted mb-0 small"><i class="bi bi-clock me-2"></i>@Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="col-sm-6 text-sm-end mt-4 mt-sm-0">
                            <div class="d-inline-block p-3 bg-gold-light rounded-4 text-center border-gold">
                                <span class="d-block small fw-bold text-dola-dark">BÀN SỐ</span>
                                <h2 class="fw-bold text-dola-dark mb-0">@Model.BanAn?.SoBan</h2>
                            </div>
                        </div>
                    </div>

                    @* Danh sách món ăn *@
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle">
                            <thead>
                                <tr class="text-dola-dark border-bottom">
                                    <th class="py-3">DANH MỤC MÓN</th>
                                    <th class="py-3 text-center">SL</th>
                                    <th class="py-3 text-end">ĐƠN GIÁ</th>
                                    <th class="py-3 text-end">THÀNH TIỀN</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.DanhSachMon != null)
                                {
                                    foreach (var item in ViewBag.DanhSachMon as List<Laptrinnhweb.Models.ChiTietDatMon>)
                                    {
                                        <tr class="border-bottom-dashed">
                                            <td class="py-3">
                                                <div class="fw-bold text-dark">@item.MonAn?.TenMon</div>
                                                <small class="text-muted">Hải sản tươi sống</small>
                                            </td>
                                            <td class="py-3 text-center">
                                                <span class="badge bg-light text-dark border">@item.SoLuong</span>
                                            </td>
                                            <td class="py-3 text-end">@item.MonAn?.Gia.ToString("N0") <small>đ</small></td>
                                            <td class="py-3 text-end fw-bold">@((item.SoLuong * item.MonAn?.Gia)?.ToString("N0")) <small>đ</small></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    @* Tổng kết tiền *@
                    <div class="row justify-content-end mt-4">
                        <div class="col-md-6 col-lg-5">
                            <div class="p-3 rounded-4 bg-light shadow-sm">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Tạm tính:</span>
                                    <span class="fw-bold">@(((List<Laptrinnhweb.Models.ChiTietDatMon>)ViewBag.DanhSachMon).Sum(x => x.SoLuong * x.MonAn?.Gia)?.ToString("N0")) đ</span>
                                </div>
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="text-muted">VAT (0%):</span>
                                    <span class="fw-bold">0 đ</span>
                                </div>
                                <div class="border-top pt-2 d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-dola-dark">TỔNG CỘNG:</span>
                                    <h4 class="fw-bold text-danger mb-0">
                                        @(((List<Laptrinnhweb.Models.ChiTietDatMon>)ViewBag.DanhSachMon).Sum(x => x.SoLuong * x.MonAn?.Gia)?.ToString("N0")) đ
                                    </h4>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Nút điều khiển *@
                    <div class="mt-5 pt-4 border-top text-center no-print d-flex justify-content-center gap-2">
                        <button onclick="window.print()" class="btn btn-outline-dola rounded-pill px-4">
                            <i class="bi bi-printer me-2"></i>In phiếu món
                        </button>

                        @* Nút dẫn tới trang Thanh toán (Checkout) *@
                        <a asp-action="Checkout" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm">
                            <i class="bi bi-wallet2 me-2"></i>Tiến hành Thanh toán
                        </a>
                    </div>

                    <div class="text-center mt-4 d-none d-print-block">
                        <hr>
                        <p class="small text-muted italic">Dola Seafood - Trải nghiệm hương vị biển khơi đích thực.</p>
                        <p class="x-small text-muted">Mã đơn: #@Model.Id | Ngày in: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f9;
    }

    .bg-dola-dark {
        background-color: #002d5b !important;
    }

    .text-dola-dark {
        color: #002d5b !important;
    }

    .invoice-card {
        border: 1px solid rgba(0,45,91,0.1) !important;
    }

    .bg-gold-light {
        background-color: #fffdf5;
    }

    .border-gold {
        border: 2px solid #ffc107 !important;
    }

    .border-bottom-dashed {
        border-bottom: 1px dashed #dee2e6;
    }

    .x-small {
        font-size: 0.75rem;
        font-weight: bold;
    }

    .btn-outline-dola {
        border-color: #002d5b;
        color: #002d5b;
        transition: 0.3s;
    }

        .btn-outline-dola:hover {
            background-color: #002d5b;
            color: white;
        }

    @@media print {
        .no-print {
            display: none !important;
        }

        .container {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
        }

        .invoice-card {
            border: none !important;
        }

        body {
            background-color: white !important;
        }
    }
</style>