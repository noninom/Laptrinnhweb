@model IEnumerable<Laptrinnhweb.Models.DatBan>

@{
    ViewData["Title"] = "Quản lý đặt chỗ";
}
<div style="padding-top: 100px; padding-bottom: 50px;">
<div class="container-fluid mt-4 px-4">
    @* Header Section - Đổi sang tông màu tối sang trọng *@
    <div class="card border-0 shadow-lg rounded-4 mb-4" style="background: #002d5b;">
        <div class="card-body d-flex justify-content-between align-items-center p-4">
            <div>
                <h2 class="fw-bold mb-1 text-warning">
                    <i class="bi bi-journal-check me-2"></i>QUẢN LÝ ĐẶT CHỖ
                </h2>
                <p class="text-white-50 mb-0">Hệ thống quản lý trạng thái bàn tiệc thời gian thực</p>
            </div>
            <a asp-controller="BanAns" asp-action="Index" class="btn btn-warning rounded-pill px-4 py-2 fw-bold shadow-sm transition-hover">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i>SƠ ĐỒ BÀN
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white shadow-sm rounded-4 border">
            <i class="bi bi-inbox text-muted display-1"></i>
            <h4 class="mt-3 text-muted">Chưa có khách hàng đặt bàn trong danh sách</h4>
            <a asp-controller="BanAns" asp-action="Index" class="btn btn-outline-primary mt-2 rounded-pill">Quay lại Sơ đồ bàn</a>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-lg rounded-4 bg-white border-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="dola-table-header">
                    <tr>
                        <th class="ps-4 py-4">KHÁCH HÀNG</th>
                        <th class="py-4">LIÊN HỆ</th>
                        <th class="py-4">THỜI GIAN ĐẶT</th>
                        <th class="py-4 text-center">TRẠNG THÁI</th>
                        <th class="py-4 text-center">VỊ TRÍ</th>
                        <th class="py-4 text-center pe-4">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="booking-row">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-dola me-3">@item.TenKhachHang.Substring(0, 1).ToUpper()</div>
                                    <div>
                                        <div class="fw-bold text-dark fs-5">@item.TenKhachHang</div>
                                        <small class="text-muted">ID: #@item.Id</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="fw-medium"><i class="bi bi-telephone-fill text-primary me-2"></i>@item.SoDienThoai</div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.NgayDat.ToString("dd/MM/yyyy")</div>
                                <div class="badge bg-light text-dark border"><i class="bi bi-clock me-1"></i>@item.NgayDat.ToString("HH:mm")</div>
                            </td>
                            <td class="text-center">
                                @if (item.TrangThai == 0)
                                {
                                    <span class="status-badge bg-secondary-subtle text-secondary">
                                        <span class="dot bg-secondary"></span>Đang chờ
                                    </span>
                                }
                                else if (item.TrangThai == 1)
                                {
                                    <span class="status-badge bg-success-subtle text-success animate-pulse">
                                        <span class="dot bg-success"></span>Đang phục vụ
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="table-tag">
                                    <i class="bi bi-geo-alt-fill me-1"></i>Bàn @item.BanAn?.SoBan
                                </div>
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group rounded-pill overflow-hidden shadow-sm">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-dola-cyan">
                                        <i class="bi bi-search me-1"></i>Xem món
                                    </a>

                                    @if (item.TrangThai == 0)
                                    {
                                        <a asp-action="NhanBan" asp-route-id="@item.Id" class="btn btn-dola-green">
                                            <i class="bi bi-check-circle me-1"></i>Nhận bàn
                                        </a>
                                    }
                                    else
                                    {
                                        <form asp-action="Checkout" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-dola-red"
                                                    onclick="return confirm('Xác nhận thanh toán và giải phóng bàn này?')">
                                                <i class="bi bi-cash-stack me-1"></i>Trả bàn
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
<div>

<style>
    /* Tổng thể giao diện */
    body {
                margin: 0;
                padding: 0;
                min-height: 100vh;
                /* Hình nền đại dương sang trọng */
                background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1559339352-11d035aa65de?auto=format&fit=crop&w=1920&q=80');
                background-size: cover;
                background-position: center;
                background-attachment: fixed;
                background-repeat: no-repeat; /* Thêm fixed */
    }

    /* Header Bảng kiểu Dola */
    .dola-table-header {
        background-color: #002d5b !important;
        border-bottom: 3px solid #ffc107;
    }

        .dola-table-header th {
            color: #ffc107 !important;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 1px;
        }

    /* Hiệu ứng dòng */
    .booking-row {
        transition: all 0.3s ease;
        border-bottom: 1px solid #f0f0f0;
    }

        .booking-row:hover {
            background-color: #f8fbff;
            transform: scale(1.005);
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            z-index: 10;
            position: relative;
        }

    /* Avatar & Tags */
    .avatar-dola {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #0d6efd, #002d5b);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        font-weight: bold;
        font-size: 1.2rem;
        box-shadow: 0 3px 6px rgba(13, 110, 253, 0.2);
    }

    .table-tag {
        background-color: #e7f3ff;
        color: #007bff;
        padding: 6px 15px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        border: 1px solid #cce5ff;
    }

    /* Badge Trạng thái */
    .status-badge {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-right: 8px;
    }

    /* Custom Buttons (Dựa theo ảnh bạn cung cấp) */
    .btn-dola-cyan {
        background-color: #00bcd4;
        color: white;
        border: none;
        padding: 8px 18px;
        font-weight: 500;
    }

        .btn-dola-cyan:hover {
            background-color: #00acc1;
            color: white;
        }

    .btn-dola-green {
        background-color: #4caf50;
        color: white;
        border: none;
        padding: 8px 18px;
        font-weight: 500;
    }

        .btn-dola-green:hover {
            background-color: #43a047;
            color: white;
        }

    .btn-dola-red {
        background-color: #ef5350;
        color: white;
        border: none;
        padding: 8px 18px;
        font-weight: 500;
    }

        .btn-dola-red:hover {
            background-color: #e53935;
            color: white;
        }

    .animate-pulse {
        animation: pulse 1.5s infinite;
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }
    }
</style>