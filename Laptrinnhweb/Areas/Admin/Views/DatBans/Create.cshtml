@model Laptrinnhweb.Models.DatBan

<div style="padding-top: 100px; padding-bottom: 50px;">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-lg border-0" style="border-radius: 15px;">
                    <div class="card-header bg-primary text-white text-center py-3" style="border-radius: 15px 15px 0 0;">
                        <h4 class="mb-0"><i class="bi bi-person-check"></i> Xác Nhận Đặt Bàn @ViewBag.TenBan</h4>
                    </div>
                    <div class="card-body p-4">
                        @* CHÚ Ý: Đổi asp-action thành ConfirmOrder nếu bạn dùng hàm mình viết ở trên *@
                        <form asp-action="ConfirmOrder" method="post">
                            <input type="hidden" asp-for="BanAnId" value="@ViewBag.TableId" />
                            <input type="hidden" name="tableId" value="@ViewBag.TableId" /> @* Thêm dòng này để khớp tham số Controller *@
                            <input type="hidden" name="cartJson" value="@ViewBag.CartJson" />

                            <div class="mb-3">
                                <label class="form-label fw-bold">Tên khách hàng</label>
                                <input name="tenKhach" class="form-control rounded-pill px-3" placeholder="Nhập tên của bạn..." required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Số điện thoại</label>
                                <input name="soDienThoai" class="form-control rounded-pill px-3" placeholder="090..." required />
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Giờ đến dự kiến</label>
                                @* Đổi NgayDat thành gioDenDuyKien *@
                                <input id="txtGioDen" name="gioDenDuyKien" class="form-control rounded-pill px-3" type="datetime-local" required />
                                <div class="form-text text-danger mt-1">
                                    <i class="bi bi-info-circle"></i> Nhà hàng sẽ giữ bàn tối đa 2 tiếng từ giờ hẹn.
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success btn-lg rounded-pill shadow-sm fw-bold">XÁC NHẬN ĐẶT BÀN</button>
                                <a asp-controller="MonAns" asp-action="Index" asp-route-banId="@ViewBag.TableId" class="btn btn-outline-secondary rounded-pill">Quay lại Menu</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        document.getElementById('txtGioDen').min = now.toISOString().slice(0, 16);
    </script>
}

<style>
    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        /* Hình nền đại dương sang trọng */
        background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1559339352-11d035aa65de?auto=format&fit=crop&w=1920&q=80');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat; /* Thêm fixed */
    }
</style>