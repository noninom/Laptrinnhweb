@model Laptrinnhweb.Models.DatBan

@{
    ViewData["Title"] = "Thanh toán hóa đơn";
    decimal tongTien = 0;
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                @* 1. Header Hóa Đơn *@
                <div class="card-header bg-dola-dark text-center py-4">
                    <h3 class="text-warning fw-bold mb-0">HÓA ĐƠN THANH TOÁN</h3>
                    <p class="text-white-50 small mb-0">Mã hóa đơn: #@Model.Id | Ngày: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h5 class="fw-bold border-bottom pb-2">Thông tin khách hàng</h5>
                            <p class="mb-1"><strong>Khách hàng:</strong> @Model.TenKhachHang</p>
                            <p class="mb-1"><strong>Số điện thoại:</strong> @Model.SoDienThoai</p>
                            <p class="mb-1"><strong>Vị trí:</strong> <span class="badge bg-primary">Bàn @Model.BanAn?.SoBan</span></p>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <h5 class="fw-bold border-bottom pb-2">Trạng thái</h5>
                            <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">
                                <i class="bi bi-check-circle-fill"></i> Sẵn sàng thanh toán
                            </span>
                        </div>
                    </div>

                    @* 2. Bảng danh sách món ăn *@
                    <div class="table-responsive mb-4">
                        <table class="table table-borderless align-middle">
                            <thead class="table-light">
                                <tr class="text-secondary small text-uppercase">
                                    <th>Món ăn</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.DanhSachMon != null)
                                {
                                    foreach (var mon in (List<Laptrinnhweb.Models.ChiTietDatMon>)ViewBag.DanhSachMon)
                                    {
                                        var thanhTien = (mon.SoLuong * (mon.MonAn?.Gia ?? 0));
                                        tongTien += (decimal)thanhTien;

                                        <tr>
                                            <td class="fw-bold">@mon.MonAn?.TenMon</td>
                                            <td class="text-center">@mon.SoLuong</td>
                                            <td class="text-end">@mon.MonAn?.Gia.ToString("N0") VNĐ</td>
                                            <td class="text-end fw-bold">@thanhTien.ToString("N0") VNĐ</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="row justify-content-end">
                        <div class="col-md-5">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Tổng tiền món:</span>
                                <span>@tongTien.ToString("N0") đ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Thuế (VAT 10%):</span>
                                <span>@((tongTien * 0.1m).ToString("N0")) đ</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="h5 fw-bold mb-0">TỔNG CỘNG:</span>
                                <span class="h3 fw-bold text-danger mb-0">@((tongTien * 1.1m).ToString("N0")) đ</span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-5">

                    @* 3. Phương thức thanh toán *@
                    <h5 class="fw-bold mb-4 text-center"><i class="bi bi-wallet2 me-2"></i>CHỌN PHƯƠNG THỨC THANH TOÁN</h5>

                    <form asp-action="ConfirmPayment" method="post" id="paymentForm">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="payment-option">
                                    <input type="radio" name="paymentMethod" value="Cash" checked>
                                    <div class="option-content">
                                        <i class="bi bi-cash-stack fs-2"></i>
                                        <span>Tiền mặt</span>
                                    </div>
                                </label>
                            </div>
                            <div class="col-md-4">
                                <label class="payment-option">
                                    <input type="radio" name="paymentMethod" value="Transfer">
                                    <div class="option-content">
                                        <i class="bi bi-bank fs-2"></i>
                                        <span>Chuyển khoản</span>
                                    </div>
                                </label>
                            </div>
                            <div class="col-md-4">
                                <label class="payment-option">
                                    <input type="radio" name="paymentMethod" value="Momo">
                                    <div class="option-content">
                                        <i class="bi bi-qr-code-scan fs-2"></i>
                                        <span>Ví điện tử</span>
                                    </div>
                                </label>
                            </div>
                        </div>

                        @* 4. Vùng hiển thị QR Code (Chỉ hiện khi chọn Chuyển khoản/Momo) *@
                        <div id="qr-display-section" class="text-center mb-5 p-4 rounded-4 shadow-sm border" style="display: none; background: #f8f9fa;">
                            <h6 class="fw-bold text-primary mb-3 text-uppercase" id="qr-title">Quét mã để thanh toán</h6>
                            <div class="d-inline-block p-3 bg-white rounded-3 shadow-sm border border-2 border-warning mb-3">
                                <img id="qr-image" src="" alt="Mã QR" style="max-width: 220px; height: auto;" />
                            </div>
                            <div>
                                <p class="mb-1 fw-bold text-danger h5">Số tiền: <span id="qr-amount-text"></span> đ</p>
                                <p class="text-muted small mb-0 px-md-5">
                                    <i class="bi bi-info-circle me-1"></i> Vui lòng quét mã và kiểm tra nội dung trước khi bấm xác nhận.
                                </p>
                            </div>
                        </div>

                        <div class="d-flex gap-3 justify-content-center">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-5 py-3 fw-bold">QUAY LẠI</a>
                            <button type="submit" class="btn btn-dola-payment rounded-pill px-5 py-3 fw-bold shadow">
                                XÁC NHẬN & XUẤT HÓA ĐƠN <i class="bi bi-printer-fill ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        /* Hình nền đại dương sang trọng */
        background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1559339352-11d035aa65de?auto=format&fit=crop&w=1920&q=80');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat; /* Thêm fixed */
	}
    .bg-dola-dark {
        background-color: #002d5b;
    }

    .payment-option {
        width: 100%;
        cursor: pointer;
    }

        .payment-option input {
            display: none;
        }

    .option-content {
        border: 2px solid #f0f0f0;
        border-radius: 15px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .payment-option input:checked + .option-content {
        border-color: #ffc107;
        background-color: #fffdf5;
        color: #002d5b;
        transform: translateY(-5px);
        box-shadow: 0 5px 15px rgba(255, 193, 7, 0.2);
    }

    .btn-dola-payment {
        background-color: #ffc107;
        color: #002d5b;
        border: none;
        transition: 0.3s;
    }

        .btn-dola-payment:hover {
            background-color: #e5ad06;
            color: #002d5b;
            transform: scale(1.02);
        }

    #qr-display-section {
        animation: fadeIn 0.4s ease-in-out;
        border-style: dashed !important;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const qrSection = document.getElementById('qr-display-section');
        const qrImage = document.getElementById('qr-image');
        const qrTitle = document.getElementById('qr-title');
        const qrAmountText = document.getElementById('qr-amount-text');
        const paymentOptions = document.querySelectorAll('input[name="paymentMethod"]');

        // Dữ liệu từ Model
        const rawAmount = "@((tongTien * 1.1m).ToString("F0"))"; // Không dấu phẩy để API đọc
        const formattedAmount = "@((tongTien * 1.1m).ToString("N0"))";
        const content = encodeURIComponent("Thanh toan Ban @Model.BanAn?.SoBan HD @Model.Id");

        function updateQR(method) {
        let qrUrl = "";
        const qrSection = document.getElementById('qr-display-section');
        const qrImage = document.getElementById('qr-image');
        const qrAmountText = document.getElementById('qr-amount-text');

        const rawAmount = "@((tongTien * 1.1m).ToString("F0"))";
        const formattedAmount = "@((tongTien * 1.1m).ToString("N0"))";
        const content = encodeURIComponent("THANH TOAN BAN @Model.BanAn?.SoBan HD @Model.Id");

        if (method === "Transfer") {
            qrUrl = `https://img.vietqr.io/image/MB-0358535214-qr_only.png?amount=${rawAmount}&addInfo=${content}`;
            qrSection.style.display = 'block';
        }
              else if (method === "Momo") {
        qrTitle.innerText = "Thanh toán qua Ví Momo";
        const sdt_cua_ban = "0933550847";

        const amount = "@((tongTien * 1.1m).ToString("F0"))";

        const note = "THANH TOAN BAN @Model.BanAn?.SoBan";

        qrUrl = `https://img.vietqr.io/image/MOMO-${sdt_cua_ban}-compact.png?amount=${amount}&addInfo=${encodeURIComponent(note)}`;

        qrImage.src = qrUrl;
        qrSection.style.display = 'block';

        qrSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
        else {
            qrSection.style.display = 'none';
        }

        if (qrUrl !== "") {
            qrImage.src = qrUrl;
            qrAmountText.innerText = formattedAmount;
            qrSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    }
    paymentOptions.forEach(opt => {
            opt.addEventListener('change', function() {
                updateQR(this.value);
            });
        });
    });
</script>