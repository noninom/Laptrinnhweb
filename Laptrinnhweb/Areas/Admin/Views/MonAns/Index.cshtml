@model IEnumerable<Laptrinnhweb.Models.MonAn>

@{
    ViewData["Title"] = "Thực Đơn Hải Sản - Dola";
    var banId = Context.Request.Query["banId"];
    var tenBan = Context.Request.Query["tenBan"];
}

<div class="container-fluid mt-4 px-4">
    @* Header Section sang trọng *@
    <div class="text-center mb-5">
        <h1 class="fw-bold text-uppercase menu-title">⚓ THỰC ĐƠN HẢI SẢN ⚓</h1>
        <div class="title-underline"></div>
        <p class="text-muted mt-2">Tinh hoa đại dương - Hương vị thượng hạng</p>
    </div>

    @{
        bool isServing = ViewBag.IsServing ?? false;
    }

    @* Thông báo trạng thái bàn - Thiết kế lại cho gọn *@
    <div class="row justify-content-center mb-4">
        <div class="col-md-8">
            @if (isServing)
            {
                <div class="alert alert-dola-warning text-center shadow-sm rounded-pill border-0 animate__animated animate__fadeIn">
                    <i class="bi bi-lightning-charge-fill me-2"></i> <strong>GỌI THÊM TẠI BÀN</strong> - Món sẽ được tự động cộng vào hóa đơn hiện tại.
                </div>
            }

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-pill text-center border-0" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(tenBan))
            {
                <div class="alert alert-dola-info text-center shadow-sm rounded-pill border-0">
                    <i class="bi bi-info-circle-fill me-2"></i> Quý khách đang chọn món cho: <span class="badge bg-white text-primary fs-6 px-3 rounded-pill shadow-sm ml-2">BÀN @tenBan</span>
                    <a asp-controller="BanAns" asp-action="Index" class="ms-3 text-white text-decoration-underline fw-bold small">Đổi bàn khác</a>
                </div>
            }
        </div>
    </div>

    @* Thanh tìm kiếm - Phong cách hiện đại *@
    <div class="row justify-content-center mb-5">
        <div class="col-md-6">
            <form asp-action="Index" method="get" class="search-box-dola shadow-lg">
                <input type="hidden" name="banId" value="@banId" />
                <input type="hidden" name="tenBan" value="@tenBan" />
                <i class="bi bi-search ms-3 text-muted"></i>
                <input type="text" name="searchString" class="form-control border-0 bg-transparent"
                       placeholder="Tìm hải sản, đồ uống..." value="@ViewData["CurrentFilter"]">
                <button type="submit" class="btn btn-dola-dark px-4 rounded-pill m-1">TÌM KIẾM</button>
            </form>
        </div>
    </div>

    @* Tab danh mục *@
    <ul class="nav nav-pills justify-content-center mb-5 gap-3" id="menuTab" role="tablist">
        <li class="nav-item">
            <button class="nav-link active menu-tab-btn" id="food-tab" data-bs-toggle="pill" data-bs-target="#food" type="button">🦀 HẢI SẢN TƯƠI SỐNG</button>
        </li>
        <li class="nav-item">
            <button class="nav-link menu-tab-btn" id="drink-tab" data-bs-toggle="pill" data-bs-target="#drink" type="button">🍺 ĐỒ UỐNG & RƯỢU</button>
        </li>
    </ul>

    <div class="tab-content">
        @{
            string[] categories = { "Food", "Drink" };
            string[] tabIds = { "food", "drink" };
        }

        @for (int i = 0; i < categories.Length; i++)
        {
            <div class="tab-pane fade @(i == 0 ? "show active" : "")" id="@tabIds[i]" role="tabpanel">
                <div class="row g-4">
                    @foreach (var item in Model.Where(x => x.Loai == categories[i]))
                    {
                        <div class="col-sm-6 col-lg-4 col-xl-3">
                            <div class="card h-100 food-card-v2 border-0 shadow-sm">
                                <div class="card-img-wrapper">
                                    <img src="/images/@item.HinhAnh" class="card-img-top" alt="@item.TenMon">
                                    <div class="price-badge">@item.Gia.ToString("N0") <small>đ</small></div>
                                </div>
                                <div class="card-body p-4 d-flex flex-column">
                                    <h5 class="fw-bold text-dark mb-2">@item.TenMon</h5>
                                    <p class="text-muted small flex-grow-1 mb-3">@item.MoTa</p>

                                    @if (!string.IsNullOrEmpty(banId))
                                    {
                                        <form asp-action="Order" method="post" class="mt-auto">
                                            <input type="hidden" name="banId" value="@banId" />
                                            <input type="hidden" name="monId" value="@item.Id" />

                                            <div class="d-flex align-items-center justify-content-between gap-2">
                                                <div class="qty-selector">
                                                    <button type="button" onclick="decrement(this)">-</button>
                                                    <input type="number" name="soLuong" value="1" min="1" readonly>
                                                    <button type="button" onclick="increment(this)">+</button>
                                                </div>
                                                <button type="submit" class="btn btn-dola-order flex-grow-1">
                                                    <i class="bi bi-cart-plus-fill me-1"></i> THÊM
                                                </button>
                                            </div>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-controller="BanAns" asp-action="Index" class="btn btn-outline-secondary rounded-pill mt-auto fw-bold">CHỌN BÀN ĐỂ ĐẶT</a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @* Footer Chốt Đơn *@
    @if (!string.IsNullOrEmpty(banId))
    {
        <div class="sticky-checkout shadow-lg animate__animated animate__slideInUp">
            <div class="container d-flex justify-content-between align-items-center">
                <div class="d-none d-md-block">
                    <span class="text-white-50">Đang phục vụ:</span>
                    <span class="fw-bold text-warning ms-2 fs-5">BÀN @tenBan</span>
                </div>
                <a asp-controller="DatBans" asp-action="Create" asp-route-tableId="@banId"
                   class="btn btn-warning btn-lg rounded-pill px-5 py-2 fw-bold text-dark shadow-sm">
                    XÁC NHẬN ĐẶT BÀN <i class="bi bi-arrow-right-circle-fill ms-2"></i>
                </a>
            </div>
        </div>
    }
</div>

<style>
    body {
        background-color: #f4f7f9;
    }

    /* Header Styles */
    .menu-title {
        color: #002d5b;
        letter-spacing: 3px;
        font-size: 2.5rem;
    }

    .title-underline {
        width: 80px;
        height: 4px;
        background: #ffc107;
        margin: 10px auto;
        border-radius: 2px;
    }

    /* Search Box */
    .search-box-dola {
        background: white;
        border-radius: 50px;
        display: flex;
        align-items: center;
        padding: 5px;
        border: 1px solid #dee2e6;
    }

    .btn-dola-dark {
        background: #002d5b;
        color: #ffc107;
        font-weight: bold;
        border: none;
    }

        .btn-dola-dark:hover {
            background: #001d3d;
            color: #ffc107;
        }

    /* Tab Buttons */
    .menu-tab-btn {
        border-radius: 50px !important;
        padding: 12px 30px !important;
        font-weight: 700 !important;
        color: #002d5b !important;
        background: #fff !important;
        border: 1px solid #002d5b !important;
    }

        .menu-tab-btn.active {
            background: #002d5b !important;
            color: #ffc107 !important;
            border: none !important;
            box-shadow: 0 4px 15px rgba(0,45,91,0.2) !important;
        }

    /* Food Card V2 */
    .food-card-v2 {
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .food-card-v2:hover {
            transform: translateY(-12px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        }

    .card-img-wrapper {
        position: relative;
        height: 200px;
        overflow: hidden;
    }

        .card-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.5s;
        }

    .food-card-v2:hover .card-img-wrapper img {
        transform: scale(1.1);
    }

    .price-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: rgba(255, 193, 7, 0.95);
        color: #002d5b;
        padding: 5px 15px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 1.1rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    /* Qty Selector */
    .qty-selector {
        display: flex;
        align-items: center;
        background: #f1f3f5;
        border-radius: 12px;
        padding: 2px;
    }

        .qty-selector button {
            width: 32px;
            height: 32px;
            border: none;
            background: white;
            border-radius: 10px;
            font-weight: bold;
        }

        .qty-selector input {
            width: 35px;
            border: none;
            background: transparent;
            text-align: center;
            font-weight: bold;
        }

    .btn-dola-order {
        background: #002d5b;
        color: white;
        border-radius: 12px;
        font-weight: bold;
        border: none;
        padding: 10px;
    }

        .btn-dola-order:hover {
            background: #004085;
            color: #ffc107;
        }

    /* Alert Styles */
    .alert-dola-info {
        background: #002d5b;
        color: white;
    }

    .alert-dola-warning {
        background: #ffc107;
        color: #002d5b;
    }

    /* Sticky Footer */
    .sticky-checkout {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 800px;
        background: #002d5b;
        padding: 15px 30px;
        border-radius: 100px;
        z-index: 1000;
        border: 2px solid #ffc107;
    }
</style>

<script>
    function increment(btn) {
        let input = btn.parentNode.querySelector('input');
        input.stepUp();
    }
    function decrement(btn) {
        let input = btn.parentNode.querySelector('input');
        if (input.value > 1) input.stepDown();
    }
</script>