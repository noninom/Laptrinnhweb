@model IEnumerable<Laptrinnhweb.Models.MonAn>

@{
    ViewData["Title"] = "Quản lý món ăn";
}

<div class="container-fluid pt-5 mt-4 px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <h2 class="mb-0 fw-bold text-dark">Quản lý món ăn</h2>
                </div>

                @* --- THANH TÌM KIẾM MỚI --- *@
                <div class="col-md-5">
                    <form asp-action="Index" method="get" class="d-flex shadow-sm rounded-pill overflow-hidden border">
                        <input type="text" name="searchString" class="form-control border-0 ps-3"
                               placeholder="Nhập tên món cần tìm..." value="@ViewData["CurrentFilter"]">
                        <button type="submit" class="btn btn-dark px-3 border-0">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>
                </div>

                <div class="col-md-3 text-end">
                    <a asp-area="Admin" asp-controller="MonAns" asp-action="Create" class="btn btn-success rounded-pill px-4">
                        <i class="bi bi-plus-circle me-1"></i> Thêm món mới
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center">ID</th>
                            <th>Ảnh</th>
                            <th>Tên món</th>
                            <th>Loại</th>
                            <th>Giá</th>
                            <th style="width: 300px;">Mô tả</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold">#@item.Id</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.HinhAnh))
                                    {
                                        <img src="/images/@item.HinhAnh" class="rounded shadow-sm" style="width:70px; height:50px; object-fit: cover;" />
                                    }
                                </td>
                                <td class="fw-bold">@item.TenMon</td>
                                <td>
                                    <span class="badge @(item.Loai == "Food" ? "bg-info text-dark" : "bg-warning text-dark")">
                                        @item.Loai
                                    </span>
                                </td>
                                <td class="text-danger fw-bold">@item.Gia.ToString("N0") đ</td>
                                <td>
                                    @* --- FIX MÔ TẢ 2 DÒNG --- *@
                                    <div class="description-truncate" title="@item.MoTa">
                                        @item.MoTa
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a asp-area="Admin" asp-controller="MonAns" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <form asp-area="Admin" asp-controller="MonAns" asp-action="Delete" method="post" onsubmit="return confirm('Xóa món này?');" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger ms-1">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* CSS để ép mô tả hiển thị đúng 2 dòng */
    .description-truncate {
        display: -webkit-box;
        -webkit-line-clamp: 2; /* Số dòng tối đa */
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.4;
        max-height: 2.8em; /* line-height * 2 */
        font-size: 0.9rem;
        color: #212529; /*
        font-weight: 500;
    }

    /* Đảm bảo bảng không bị vỡ khi màn hình nhỏ */
    .table th {
        white-space: nowrap;
    }
</style>