@page
@model RegisterModel
@{
    ViewData["Title"] = "Tạo tài khoản mới";
}


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-success text-white text-center py-4 border-0 rounded-top-4">
                    <h3 class="fw-bold mb-0">
                        <i class="bi bi-person-plus-fill"></i> @ViewData["Title"]
                    </h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <p class="text-center text-secondary mb-4 small">Vui lòng điền đầy đủ thông tin để tham gia hệ thống</p>

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.FullName" class="form-control rounded-pill px-4" autocomplete="fullname" placeholder="Họ và Tên" />
                            <label class="px-4" asp-for="Input.FullName">Họ và Tên</label>
                            <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control rounded-pill px-4" autocomplete="username" placeholder="name@example.com" />
                            <label class="px-4" asp-for="Input.Email">Email đăng nhập</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.Password" class="form-control rounded-pill px-4" autocomplete="new-password" placeholder="password" />
                                    <label class="px-4" asp-for="Input.Password">Mật khẩu</label>
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.ConfirmPassword" class="form-control rounded-pill px-4" autocomplete="new-password" placeholder="password" />
                                    <label class="px-4" asp-for="Input.ConfirmPassword">Nhập lại</label>
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-success rounded-pill shadow-sm fw-bold mt-2">
                            TẠO TÀI KHOẢN
                        </button>
                    </form>

                    <div class="mt-4 text-center border-top pt-3">
                        <p class="mb-0 small text-secondary">
                            Đã có tài khoản? <a asp-page="./Login" class="text-success fw-bold text-decoration-none">Đăng nhập tại đây</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}