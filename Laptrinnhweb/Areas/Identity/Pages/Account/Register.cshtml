@page
@model RegisterModel
@{
    ViewData["Title"] = "Tạo tài khoản mới";
    
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            background: url('/images/restaurant.jpg') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            z-index: 1;
        }

        .register-container {
            position: relative;
            z-index: 2;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .register-card {
            width: 550px;
            padding: 40px;
            border-radius: 25px;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(15px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.5);
            color: white;
        }

            .register-card h2 {
                text-align: center;
                margin-bottom: 30px;
                font-weight: bold;
            }

        /* Ô nhập liệu: Bỏ Floating Label để tránh đè chữ */
        .form-control {
            background: rgba(255,255,255,0.2) !important;
            border: none;
            color: white !important;
            border-radius: 30px;
            padding-left: 50px; /* Chừa chỗ cho icon */
            height: 55px;
            font-size: 1rem;
        }

            .form-control::placeholder {
                color: rgba(255,255,255,0.7);
            }

            .form-control:focus {
                box-shadow: 0 0 10px #ffc107;
                background: rgba(255,255,255,0.25) !important;
            }

        /* Icon căn giữa theo chiều dọc ô input */
        .input-group-custom {
            position: relative;
            margin-bottom: 20px;
        }

        .input-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #ffc107;
            font-size: 1.2rem;
            z-index: 5;
        }

        .btn-register {
            width: 100%;
            border-radius: 30px;
            background: linear-gradient(45deg, #ff5722, #ff9800);
            border: none;
            padding: 14px;
            font-weight: bold;
            color: white;
transition: 0.3s;
            margin-top: 10px;
        }

            .btn-register:hover {
                transform: scale(1.02);
                box-shadow: 0 5px 15px rgba(255, 87, 34, 0.4);
            }

        .extra-links {
            text-align: center;
            margin-top: 20px;
        }

            .extra-links a {
                color: #ffc107;
                text-decoration: none;
            }

        /* Chỉnh màu validation error cho dễ nhìn trên nền tối */
        .text-danger {
            color: #ff9b9b !important;
            font-size: 0.85rem;
            margin-left: 15px;
        }
</style>
</head>
<body>

    <div class="overlay"></div>

    <div class="register-container">
        <div class="register-card">
            <h2><i class="bi bi-person-plus"></i> Đăng ký</h2>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <!-- Họ và Tên -->
                <div class="input-group-custom">
                    <i class="bi bi-person input-icon"></i>
                    <input asp-for="Input.FullName" class="form-control" placeholder="Họ và Tên" />
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>

                <!-- Email -->
                <div class="input-group-custom">
                    <i class="bi bi-envelope input-icon"></i>
                    <input asp-for="Input.Email" class="form-control" placeholder="Email đăng nhập" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <!-- Mật khẩu -->
                <div class="row g-2">
                    <div class="col-md-6">
                        <div class="input-group-custom">
                            <i class="bi bi-lock input-icon"></i>
                            <input asp-for="Input.Password" type="password" class="form-control" placeholder="Mật khẩu" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="input-group-custom">
                            <i class="bi bi-shield-check input-icon"></i>
                            <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-register">✨ TẠO TÀI KHOẢN</button>

                <div class="extra-links">
                    <p>Đã có tài khoản? <a asp-page="./Login">Đăng nhập ngay</a></p>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>