@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-4 border-0 rounded-top-4">
                    <h3 class="fw-bold mb-0">
                        <i class="bi bi-shield-lock-fill"></i> @ViewData["Title"]
                    </h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control rounded-pill px-4" autocomplete="username" placeholder="name@example.com" />
                            <label class="px-4" asp-for="Input.Email">Địa chỉ Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control rounded-pill px-4" autocomplete="current-password" placeholder="password" />
                            <label class="px-4" asp-for="Input.Password">Mật khẩu</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-4 ms-2">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label small text-secondary" asp-for="Input.RememberMe">
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary rounded-pill shadow-sm fw-bold transition-all">
                            ĐĂNG NHẬP
                        </button>

                        <div class="mt-4 text-center border-top pt-3">
                            <p class="mb-1 small">
                                <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none">Quên mật khẩu?</a>
                            </p>
                            <p class="mb-0 small">
                                Chưa có tài khoản? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-bold text-decoration-none">Đăng ký ngay</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}