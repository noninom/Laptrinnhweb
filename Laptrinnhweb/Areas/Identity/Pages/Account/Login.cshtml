@page
@model LoginModel

@{
    ViewData["Title"] = "Restaurant Login";

}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
    body {
        margin: 0 !important;
        padding: 0 !important;
        height: 100vh;
        width: 100vw;
        background: url('/images/restaurant.jpg') no-repeat center center fixed; /* Thêm fixed */
        background-size: cover;
        font-family: 'Segoe UI', sans-serif;
        overflow-x: hidden; /* Tránh thanh cuộn ngang */
    }

    /* Đảm bảo overlay bao phủ toàn bộ */
    .overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
        z-index: 1;
    }

    .login-container {
        position: relative;
        z-index: 2;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .login-card {
        width: 500px; /* Tăng từ 420px lên 500px */
        padding: 50px; /* Tăng khoảng cách đệm bên trong */
        border-radius: 25px;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(20px); /* Tăng độ nhòe cho sang hơn */
        box-shadow: 0 15px 50px rgba(0,0,0,0.6);
        color: white;
    }

        .login-card h2 {
            text-align: center;
            margin-bottom: 35px;
            font-size: 2rem; /* Tăng kích thước chữ tiêu đề */
            font-weight: bold;
        }

    /* Làm các ô Input to và cao hơn */
    .form-control {
        background: rgba(255,255,255,0.2);
        border: none;
        color: white;
        border-radius: 35px;
        padding-left: 55px; /* Tăng để không đè lên icon to hơn */
        height: 60px; /* Tăng chiều cao ô nhập */
        font-size: 1.1rem; /* Chữ nhập vào to hơn */
    }

    /* Phóng to Icon trong ô nhập */
    .input-icon {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: #ffc107;
        font-size: 1.3rem; /* Tăng kích thước icon */
    }

    /* Nút bấm to và mạnh mẽ hơn */
    .btn-login {
        width: 100%;
        border-radius: 35px;
        background: linear-gradient(45deg, #ff9800, #ff5722);
        border: none;
        padding: 15px; /* Nút cao hơn */
        font-size: 1.2rem; /* Chữ nút to hơn */
        font-weight: bold;
        transition: 0.3s;
        margin-top: 10px;
    }

        .btn-login:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 20px rgba(0,0,0,0.5);
        }

    .extra-links {
        text-align: center;
        margin-top: 20px;
        font-size: 14px;
    }

        .extra-links a {
            color: #ffc107;
            text-decoration: none;
        }

            .extra-links a:hover {
                text-decoration: underline;
            }
</style>

<div class="overlay"></div>
<div class="login-container">
    <div class="login-card">

        <h2><i class="bi bi-shop"></i> Đăng nhập</h2>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-warning small mb-2"></div>

            <!-- Email -->
            <div class="mb-3 position-relative">
                <i class="bi bi-envelope input-icon"></i>
                <input asp-for="Input.Email" class="form-control" placeholder="Email">
            </div>

            <!-- Password -->
            <div class="mb-3 position-relative">
                <i class="bi bi-lock input-icon"></i>
                <input asp-for="Input.Password" class="form-control" placeholder="Mật khẩu">
            </div>

            <!-- Remember -->
            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Input.RememberMe">
                <label class="form-check-label">
                    Ghi nhớ đăng nhập
                </label>
            </div>

            <!-- Button -->
            <button type="submit" class="btn btn-login">
                🔥 ĐĂNG NHẬP
            </button>

            <!-- Links -->
            <div class="extra-links">
                <p><a asp-page="./ForgotPassword">Quên mật khẩu?</a></p>
                <p>
                    Chưa có tài khoản?
                    <a asp-page="./Register">Đăng ký ngay</a>
                </p>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}